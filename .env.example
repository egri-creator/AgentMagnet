# AgentMagnet — Global Configuration
# Prefix ALL vars with AM_

# === Identity ===
AM_SERVER_NAME=AgentMagnet
AM_SERVER_VERSION=2.0.0

# === x402 Protocol (Base chain USDC micropayments) ===
AM_X402_WALLET_ADDRESS=
AM_X402_PRIVATE_KEY=
AM_X402_PRICE_PER_SEARCH=0.001
AM_X402_CHAIN_ID=8453

# === Amazon ===
# PAAPI credentials for REAL product data (optional — mock mode works without these)
AM_AMAZON_PAAPI_KEY=
AM_AMAZON_PAAPI_SECRET=
# Associate tags for 22 stores (use EITHER individual vars OR JSON)
# JSON format: {"com":"tag-20","de":"tag-21","co.uk":"tag-22","fr":"tag-23",...}
AM_AMAZON_STORE_TAGS={}
# Individual tags (used if JSON is empty):
AM_AMAZON_TAG_US=agentmagnet-21
AM_AMAZON_TAG_UK=
